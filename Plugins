local function IdToLink(Id)
	if game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 1 then
		return "rbxassetid://"..Id
	elseif game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 13 then
		return "https://www.roblox.com/asset-thumbnail/image?assetId="..Id.."&width=420&height=420&format=png"
	end
end

local function DisplayPlugin(Table)
	GUI["NoPlugins_023"].Visible = false
	local PluginName = Table.PluginName
	local PluginLogo = Table.PluginLogo
	local PluginCreator = Table.PluginCreator
	local Scripts = Table.Scripts

	print(PluginName)
	print(PluginLogo)

	_G.CreateTabButton("PLUGIN_"..PluginName, IdToLink(PluginLogo), 102)
	_G.CreatePluginTab(PluginName, IdToLink(PluginLogo), PluginCreator, Scripts)

	local Template = GUI["Template_017"]:Clone()

	Template.Name = PluginName
	Template.Parent = GUI["ScrollingFrame_016"]
	Template.Visible = true
	Template.PluginName.Text = PluginName
	Template.DeleteButton.MouseButton1Click:Connect(function()
		_G.PopUpNotificationOptions({
			Title = "Hey!",
			Message = "Are you sure you want to delete this plugin?",
			Button1Text = "Nevermind",
			Button1Function = function()
			end,
			Button2Text = "Yes",
			Button2Function = function()
				delfile("VexHub7/Plugins/"..PluginName..".vexp")
				Template:Destroy()

				local NewTable = {}
				for i, v in _G.Table.Plugins do
					if i ~= PluginName then
						NewTable[i] = v
					end
				end
				_G.Table.Plugins = NewTable

				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.Insides.Margin.Pages["PLUGIN_"..PluginName]:Destroy()
				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.SideFrame.TabChoices["PLUGIN_"..PluginName]:Destroy()

				if next(_G.Table.Plugins) == nil then
					GUI["NoPlugins_023"].Visible = true
				end

				_G.PopUpNotificationOptions({
					Title = "Deleted!",
					Message = "Plugin has been deleted successfully.",
					Button2Text = "Ok",
					Button2Function = function()
					end,
				})
			end,
		})
	end)
end

local function InstallOperation()
	_G.PopUpNotificationOptions({
		Title = "Installing...",
		Button2Text = "Ok",
		Button2Function = function()
		end,
	})

	local AllSpaces = true

	for i, v in string.split(TextBox.ContentText, " ") do
		if v ~= " " then
			AllSpaces = false
		end
	end

	function CheckIfTable(str)
		local func, loadError = loadstring(str)

		if not func then
			return false
		else

			local success, result = pcall(func)

			if success and type(result) == "table" then
				return true
			else
				return false
			end
		end
	end

	if AllSpaces == false and CheckIfTable(TextBox.ContentText) == true then
		local TableContents = loadstring(TextBox.ContentText)()

		local required = {"PluginName", "PluginLogo", "PluginCreator", "Scripts" }
		local missing = {}

		for _, key in ipairs(required) do
			if not TableContents[key] then
				table.insert(missing, key)
			end
		end

		if #missing == 0 then
			local function CheckIfDecalOrImage(Id)
				local Success, Error = pcall(function() 
					if game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 0 then end
				end)

				if Success then
					if game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 1 or game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 13 then
						return true
					end
				end
			end

			if CheckIfDecalOrImage(tonumber(TableContents.PluginLogo)) == true then
				local required = {"Creator", "PlaceId", "RigType", "Script" }
				local missing = {}

				for PluginScriptName, PluginScriptTable in TableContents.Scripts do
					for _, key in ipairs(required) do
						if not PluginScriptTable[key] then
							table.insert(missing, PluginScriptName.."."..key)
						end
					end
				end

				if #missing == 0 then
					if isfile("VexHub7/Plugins/"..TableContents.PluginName..".vexp") then
						writefile("VexHub7/Plugins/"..TableContents.PluginName..".vexp", GUI["TextBox_033"].ContentText)

						game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.Insides.Margin.Pages["PLUGIN_"..TableContents.PluginName]:Destroy()
						game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.SideFrame.TabChoices["PLUGIN_"..TableContents.PluginName]:Destroy()
						GUI["ScrollingFrame_016"][TableContents.PluginName]:Destroy()

						_G.Table.Plugins[TableContents.PluginName] = TableContents

						DisplayPlugin(TableContents)

						_G.PopUpNotificationOptions({
							Title = "Updated!",
							Message = "Plugin has been updated.",
							Button2Text = "Ok",
							Button2Function = function()
							end,
						})
					else
						writefile("VexHub7/Plugins/"..TableContents.PluginName..".vexp", GUI["TextBox_033"].ContentText)
						DisplayPlugin(TableContents)

						_G.PopUpNotificationOptions({
							Title = "Installed!",
							Message = "Plugin has been installed.",
							Button2Text = "Ok",
							Button2Function = function()
							end,
						})
					end
				else
					_G.PopUpNotificationOptions({
						Title = "Failed!",
						Message = "Missing data:"..table.concat(missing, " "),
						Button2Text = "Ok",
						Button2Function = function()
						end,
					})
				end
			else
				_G.PopUpNotificationOptions({
					Title = "Failed!",
					Message = "Please use a valid Decal or Image ID.",
					Button2Text = "Ok",
					Button2Function = function()
					end,
				})
			end
		else
			_G.PopUpNotificationOptions({
				Title = "Failed!",
				Message = "Missing data:"..table.concat(missing, " "),
				Button2Text = "Ok",
				Button2Function = function()
				end,
			})
		end
	else
		_G.PopUpNotificationOptions({
			Title = "Failed!",
			Message = "Please install a valid Table.",
			Button2Text = "Ok",
			Button2Function = function()
			end,
		})
	end

	GUI["TextBox_033"].Text = ""
end

