_G.CreateSettingTextBox(
	"UIFont",
	function() return _G.Table.GUISettings.UIFont end,
	"The font of texts in the UI",
	"FontName",
	function(TextEntered)
		local FontFound = false

		for FontName, FontID in _G.Table.Fonts do
			if string.find(string.lower(FontName), string.lower(TextEntered)) then
				_G.Table.GUISettings.UIFont = FontName
				FontFound = true
				SaveSettings()

				_G.CloseVexHub()
				for _, Child in game:GetService("CoreGui").VexHubUI:GetDescendants() do
					if (Child:GetAttribute("UIFont")) then
						Child.FontFace = UIFont(Child:GetAttribute("UIFont"))
					end
				end
				_G.OpenVexHub()
				break
			end
		end

		if FontFound == false then
			_G.PopUpNotificationOptions({
