local NewAdName = ""
local NewAdType = ""
local NewAdImage = ""
local NewAdScript = ""

for AdId, AdInfo in FirebaseServer.Ads do
	if AdInfo.Publisher == LocalPlayer.UserId then
		local AdReach = 0
		local AdClicks = 0

		for i in AdInfo.Reach do
			AdReach += 1
		end

		for i in AdInfo.Clicks do
