local function PostMessage(Table)
	coroutine.wrap(function()
		if RunOperations == true then
			local Username = Table.Username
			local DisplayName = Table.DisplayName
			local MessageId = Table.MessageId
			local Message = Table.Message

			FirebaseServerUpdate()
			if not LiveChatServer.Chats["Message"..MessageId] then
				FirebaseServerWrite("Chats", "Message"..MessageId, {
					Username = Username,
					DisplayName = DisplayName,
					Message = Message,
					UNIXTimestamp = tonumber(os.time()),
				})
			else
				MessageId += 1
				PostMessage({
					Username = Table.Username,
					DisplayName = Table.DisplayName,
					Message = Table.Message,
					MessageId = MessageId
				})
			end
		end
	end)()
end

