					local Description = JSon:Decode(game:HttpGet("https://users.roblox.com/v1/users/"..LocalPlayer.UserId))["description"]

					if string.find(Description, expandAcronym(HWID())) then
						FirebaseServerWrite("VerifiedHWID", Username, HWID())

						_G.PopUpNotificationOptions({
							Title = "Account verified!",
							Button2Text = "Ok",
