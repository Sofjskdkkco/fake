local Errors = 0

local function Load(Name, Link)
	NewMessage("Loading "..Name.."...")
	local success, result = pcall(function()
		loadstring(game:HttpGet((Link),true))()
	end)

	if success then
		NewMessage("Loaded "..Name.."...")
	else
		Errors += 1
		NewMessage("An error occured: "..result)
	end

	wait()
end

