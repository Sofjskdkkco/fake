local function TextContentToShow(Table)
	local Message = Table.Message
	local Username = Table.Username
	local DisplayName = Table.DisplayName
	local UNIXTimestamp = Table.UNIXTimestamp
	local MessageId = Table.MessageId
	local IsTemporary = Table.IsTemporary
	local IsClient = Table.IsClient
	local ContentText = ""

	if RunOperations == true then
		if LiveChatServer.VerifiedPeople[Username] then
			ContentText = utf8.char("0xE000")..' <b>'..DisplayName..'</b> <font transparency="0.3"><font size="8">(@'..Username..') '..os.date("%m/%d/%Y %I:%M %p", UNIXTimestamp)
		else
			ContentText = '<b>'..DisplayName..'</b> <font transparency="0.3"><font size="8">(@'..Username..') '..os.date("%m/%d/%Y %I:%M %p", UNIXTimestamp)
		end
	else
		ContentText = '<b>'..DisplayName..'</b> <font transparency="0.3"><font size="8">(@'..Username..') '..os.date("%m/%d/%Y %I:%M %p", UNIXTimestamp)
	end

	local NewMessage = ""
	for _, Word in string.split(Message, " ") do
		local LowWord = string.lower(Word)

		if string.find(LowWord, "@") then
			NewMessage = NewMessage..'<b><mark color="#31304f" transparency="0"><font color="#9db0f1">'..Word..'</font></mark></b> '
		else
			NewMessage = NewMessage..""..Word.." "
		end
	end

	Message = NewMessage

	if MessageId == nil then
		ContentText = ContentText..'</font></font>'
	else
		ContentText = ContentText.. " (#"..MessageId..")</font></font>"
	end

	if IsTemporary == true then
		ContentText = ContentText..'\n<font transparency="0.3">'..Message..'</font>'
	else
		ContentText = ContentText.. '\n'..Message
	end

	if IsClient == true then
		ContentText = ContentText..'\n<font size="8"><font transparency="0.3">👁️ Only you can see this message</font></font>'
	end

	return ChangeRichTextSize(ContentText, _G.Table.GUISettings.UITextSize)
end

local function DisplayMessage(Table)
	local Message = Table.Message
	local Username = Table.Username
	local DisplayName = Table.DisplayName
	local UNIXTimestamp = Table.UNIXTimestamp
	local MessageId = Table.MessageId
	local IsTemporary = Table.IsTemporary
	local IsClient = Table.IsClient

	local MessageTable = string.split(Message, " ")

	local NewMessage = GUI["MessageTemplate_013"]:Clone()
	local ContentText = TextContentToShow(Table)

	NewMessage.Parent = GUI["Chats_011"]

	for _, Word in MessageTable do
		Word = string.lower(Word)

		if string.find(Word, "@"..string.lower(LocalPlayer.Name)) or string.find(Word, "@"..string.lower(LocalPlayer.DisplayName)) or string.find(Word, "@everyone") then
			NewMessage.BackgroundTransparency = 0.8
		end
	end

	if Username == "System" then
		NewMessage.ProfilePicture.Image = "rbxassetid://14586188666"
	else
		NewMessage.ProfilePicture.Image = "https://www.roblox.com/headshot-thumbnail/image?userId="..game:GetService("Players"):GetUserIdFromNameAsync(Username).."&width=420&height=420&format=png"
	end

	if RunOperations == true then
		if LiveChatServer.VerifiedPeople[Username] then
			NewMessage.ProfilePicture.UIStroke.Color = Color3.fromRGB(51, 95, 255)
		end
	end

	if IsTemporary == true then
		NewMessage.Name = "Temporary"..math.random(100000, 999999)
		NewMessage.LayoutOrder = 1000000

		coroutine.wrap(function()
			wait(5)
			NewMessage:Destroy()
		end)()
	else		
		NewMessage.Name = "Message"..MessageId
		NewMessage.LayoutOrder = MessageId
	end

	if IsClient == true then
		NewMessage.Name = "Client"
		NewMessage.LayoutOrder = 1000000

		coroutine.wrap(function()
			wait(10)
			NewMessage:Destroy()
		end)()
	end

	local isAtBottom = false
	local function isAtBottom()
		return Chats.CanvasPosition.Y >= Chats.AbsoluteCanvasSize.Y - Chats.AbsoluteWindowSize.Y - 10
	end
	if isAtBottom() then isAtBottom = true end

	NewMessage.Message.Text = ContentText
	NewMessage.Visible = true

	if isAtBottom == true or Username == LocalPlayer.Name or string.find(string.lower(Message), "@everyone") or string.find(string.lower(Message), "@"..string.lower(LocalPlayer.Name)) or string.find(string.lower(Message), "@"..string.lower(LocalPlayer.DisplayName)) then
		scrollToBottom()
	end

	return NewMessage.Name
end

