local function ShowAd(AdImageId)
	GUI.Ad_0.Image = "rbxassetid://"..AdImageId
	game:GetService("ContentProvider"):PreloadAsync({GUI.Ad_0.Image})

	GUI.Ad_0.Visible = true
	TweenService:Create(GUI.PopUpAd_0, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0.7}):Play()
	TweenService:Create(GUI.Ad_0, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {ImageTransparency = 0}):Play()
	TweenService:Create(GUI.Ad_0.UIScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
end

local Secret = "1Aq8ET3WbsdhKUSRvrKzHRhVdgUMQq4GYSuVlEX8"
local URL = "https://vexhub-general-server-default-rtdb.firebaseio.com/"

local FirebaseServer = {}

local function FirebaseServerWrite(Path, Key, Value)
	local success, error = pcall(function()
		local database = URL..Path..".json?auth="..Secret
		local request = request or syn.request
		local Table = {}

		if game.HttpService:JSONDecode(game:HttpGetAsync(database)) ~= nil then
			for key, value in pairs(game:GetService("HttpService"):JSONDecode(game:HttpGetAsync(database))) do
				if key then
					Table[key] = value
				end
			end
		end

		Table[Key] = Value

		local send = request({
			Url = database,
			Method = "PUT",
			Headers = {["Content-Type"] = "application/json"},
			Body = game:GetService("HttpService"):JSONEncode(Table)
		})
	end)

	if not success then print("Something went wrong while writing in the server: "..error) end
end

local function FirebaseServerDelete(Path, Key)
	local success, error = pcall(function()
		local database = URL..Path..".json?auth="..Secret
		local request = request or syn.request
		local Table = {}

		if game.HttpService:JSONDecode(game:HttpGetAsync(database)) ~= nil then
			for key, value in pairs(game:GetService("HttpService"):JSONDecode(game:HttpGetAsync(database))) do
				if key ~= Key then
					Table[key] = value
				end
			end
		end

		local send = request({
			Url = database,
			Method = "PUT",
			Headers = {["Content-Type"] = "application/json"},
			Body = game.HttpService:JSONEncode(Table)
		})
	end)

	if not success then print("Something went wrong while deleting in the server: "..error) end
end

local function FirebaseServerUpdate()
	local success, error = pcall(function()
		FirebaseServer = game.HttpService:JSONDecode(game:HttpGetAsync(URL..".json?auth="..Secret))
	end)

	if not success then print("Something went wrong while reading in the server: "..error) end
end

local function AdOperation()
	if math.random(1, 10) == 1 and Cooldown == 0 then
		FirebaseServerUpdate()
		local AdToRun = nil
		local Ads = {}

		local success, result = pcall(function()
			if FirebaseServer.Ads ~= nil then
				for AdId, AdInfo in FirebaseServer.Ads do			
					if AdInfo.Expiration > os.time() then
						if AdInfo.Type == "PopUp" then
							for i = 1, AdInfo.ReachLevel do
								table.insert(Ads, AdId)
							end
						end
					else
						local success, result = pcall(function()
							FirebaseServerDelete("Ads", AdId)
						end)

						if not success then
							print("Failed to delete a pop-up ad: "..result)
						end
					end
					wait()
				end
			else
				print("Aborted popup ad operation: FirebaseServer.Ads does not exist")
				return false
			end
		end)

		if success then
			if #Ads ~= 0 then
				AdToRun = Ads[math.random(1, #Ads)]
			end

			if AdToRun ~= nil then
				local AdInfo = Ads[AdToRun]
				FirebaseServerUpdate()
				FirebaseServerWrite("Ads/"..AdToRun.."/Reach", LocalPlayer.UserId, true)
				FirebaseServerWrite("Ads/"..AdToRun, "Impressions", FirebaseServer.Ads[AdToRun].Impressions+1)
				AdFrameFunction:Disconnect()
				ShowAd(FirebaseServer.Ads[AdToRun].Image)
				MainContents.Interactable = false
				Cooldown = 60
				wait(1)
				AdFrameFunction = GUI.Ad_0.MouseButton1Down:Connect(function()
					FirebaseServerWrite("Ads/"..AdToRun.."/Clicks", LocalPlayer.UserId, true)
					loadstring(FirebaseServer.Ads[AdToRun].Script)()
				end)
			end
		else
			print("Failed to load pop-up ads: "..result)
		end
	end
end

