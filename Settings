_G.CreateSettingTextBox(
	"Wallpaper",
	function() return _G.Table.GUISettings.Wallpaper end,
	"The image of the UI background",
	"png/ID/link",
	function(TextEntered)
		function CheckIfDecalOrImage(Id)
			local Success, Error = pcall(function() 
				if game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 0 then end
			end)

			if Success then
				if game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 1 then
					return "Image"
				elseif game:GetService("MarketplaceService"):GetProductInfo(tonumber(Id)).AssetTypeId == 13 then
					return "Decal"
				end
			end
		end

		if string.find(TextEntered, "http://") or string.find(TextEntered, "https://") then
			local ImageName = game:GetService("HttpService"):GenerateGUID(false)
			local ImagePath = "VexHub7/Wallpapers/"..ImageName..".png"
			writefile(ImagePath, game:HttpGet(TextEntered))

			game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.Image = getcustomasset(ImagePath)
			game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.WallpaperCover.Image = getcustomasset(ImagePath)

			_G.Table.GUISettings.Wallpaper = ImagePath
			SaveSettings()

		elseif string.find(string.lower(TextEntered), ".png") then
			if isfile(TextEntered) then
				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.Image = getcustomasset(TextEntered)
				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.WallpaperCover.Image = getcustomasset(TextEntered)

				_G.Table.GUISettings.Wallpaper = TextEntered
				SaveSettings()
			else
				_G.PopUpNotificationOptions({
					Title = "Error!",
					Message = "Invalid path",
					Button2Text = "Close",
					Button2Function = function()
					end,
				})
			end

		elseif tonumber(TextEntered) then
			if CheckIfDecalOrImage(TextEntered) == "Image" then
				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.Image = "rbxassetid://"..TextEntered
				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.WallpaperCover.Image = "rbxassetid://"..TextEntered

				_G.Table.GUISettings.Wallpaper = TextEntered
				SaveSettings()
			elseif CheckIfDecalOrImage(TextEntered) == "Decal" then
				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.Image = "https://www.roblox.com/asset-thumbnail/image?assetId="..TextEntered.."&width=420&height=420&format=png"
				game:GetService("CoreGui").VexHubUI.DragFrame.MainFrame.MainContents.RightFrame.Wallpaper.WallpaperCover.Image = "https://www.roblox.com/asset-thumbnail/image?assetId="..TextEntered.."&width=420&height=420&format=png"

				_G.Table.GUISettings.Wallpaper = TextEntered
				SaveSettings()
			else
				_G.PopUpNotificationOptions({
					Title = "Error!",
					Message = "Invalid ID.",
					Button2Text = "Close",
					Button2Function = function()
					end,
				})
			end

		else
			_G.PopUpNotificationOptions({
				Title = "Error!",
				Message = "Invalid input. Must be a ID, PNG, or Link.",
				Button2Text = "Close",
				Button2Function = function()
				end,
			})
		end
	end
)

