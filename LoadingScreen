local URL = "https://vexhub-general-server-default-rtdb.firebaseio.com/"

local FirebaseServer = {}

local function FirebaseServerWrite(Path, Key, Value)
	local database = URL..Path..".json?auth="..Secret
	local request = request or syn.request
	local Table = {}

	if game.HttpService:JSONDecode(game:HttpGetAsync(database)) ~= nil then
		for key, value in pairs(game:GetService("HttpService"):JSONDecode(game:HttpGetAsync(database))) do
			if key then
				Table[key] = value
			end
		end
	end

	Table[Key] = Value

	local send = request({
		Url = database,
		Method = "PUT",
		Headers = {["Content-Type"] = "application/json"},
		Body = game:GetService("HttpService"):JSONEncode(Table)
	})
end

local function FirebaseServerUpdate()
	FirebaseServer = game.HttpService:JSONDecode(game:HttpGetAsync(URL..".json?auth="..Secret))
end

